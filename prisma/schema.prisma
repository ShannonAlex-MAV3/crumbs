generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  picture        String?
  provider       Provider
  providerUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  status         Status   @default(ACT)

  @@map("t_user")
}

enum Status {
  ACT
  INA
}

enum Provider {
  GOOGLE
}
